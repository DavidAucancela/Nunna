{
  "name": "@seres-del-pase/web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && cp -r public .next/standalone/apps/web/public && cp -r .next/static .next/standalone/apps/web/.next/static",
    "start": "PORT=${PORT:-3000} HOSTNAME=0.0.0.0 node .next/standalone/apps/web/server.js",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf .next out"
  },
  "dependencies": {
    "@seres-del-pase/types": "workspace:*",
    "@seres-del-pase/ui": "workspace:*",
    "@supabase/supabase-js": "^2.45.0",
    "@tailwindcss/typography": "^0.5.19",
    "framer-motion": "^11.18.2",
    "lenis": "^1.1.20",
    "maplibre-gl": "^4.7.1",
    "next": "15.5.18",
    "next-intl": "^3.26.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@seres-del-pase/config": "workspace:*",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.5.18",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  }
}
