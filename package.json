{
  "name": "seres-del-pase",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo run build --filter @seres-del-pase/web",
    "start": "pnpm --filter @seres-del-pase/web start",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@seres-del-pase/config": "workspace:*",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0"
}
