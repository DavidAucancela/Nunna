# ─────────────────────────────────────────────────────────────────────────────
# Seres del Pase — Variables de entorno
# Copia este archivo a .env.local y rellena los valores
# NUNCA commitees el .env.local real
# ─────────────────────────────────────────────────────────────────────────────

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Directus (CMS)
DIRECTUS_URL=http://localhost:8055
DIRECTUS_STATIC_TOKEN=your_static_token_here

# NestJS API
API_PORT=3001
API_DATABASE_URL=postgresql://user:password@localhost:5432/seres_del_pase

# OpenAI (embeddings para búsqueda semántica, Fase 2)
OPENAI_API_KEY=sk-...

# Analytics (Plausible)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=seresxxx.com

# Sentry
SENTRY_DSN=https://xxx@sentry.io/xxx
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx

# Internacionalización
NEXT_PUBLIC_DEFAULT_LOCALE=es
